/*
 * Basic Example
 *
 * Shows how to define a directory resource using the localfs plugin.
 * Run with: formae apply --mode reconcile --watch examples/basic/main.pkl
 */
amends "@formae/forma.pkl"

import "@formae/formae.pkl"
import "@localfs/localfs.pkl"

forma {
  new formae.Stack {
    label = "default"
    description = "Default stack for localfs example"
  }

  new formae.Target {
    label = "my-target"
    config = new localfs.Config { basePath = "/tmp/localfs-example" }
  }

  new localfs.Directory {
    label = "my-dir"
    path = "subdir"
    permissions = "0755"
  }
}
