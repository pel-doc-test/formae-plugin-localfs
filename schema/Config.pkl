/// Plugin configuration for the localfs plugin.
///
/// Users import this via: import "plugins:/localfs.pkl" as localfs
///
/// Then use it in their formae.conf.pkl:
///   agent {
///       resourcePlugins {
///           new localfs.PluginConfig {
///               rateLimit { maxRequestsPerSecond = 10 }
///           }
///       }
///   }
open module localfs.Config

extends "formae:/Config.pkl"

class PluginConfig extends BaseResourcePluginConfig {
    type = "localfs"
}
